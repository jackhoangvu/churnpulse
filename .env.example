# -- Supabase -----------------------------------------------------
# https://supabase.com -> Project Settings -> API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- Clerk Auth ---------------------------------------------------
# https://dashboard.clerk.com -> API Keys
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# -- Polar OAuth (primary billing platform) -----------------------
# https://polar.sh/settings -> Developer -> OAuth Apps
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_SCOPES=openid email organizations:read customers:read subscriptions:read orders:read webhooks:write customer_sessions:write
POLAR_ACCESS_TOKEN=

# -- Stripe Connect (monitoring customers' Stripe) ----------------
# https://dashboard.stripe.com -> Developers -> Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_SCOPE=read_only

# -- Paddle (monitoring customers' Paddle) ------------------------
# https://sandbox.paddle.com -> Developer Tools -> Notifications
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# -- Lemon Squeezy (monitoring customers' LS) ---------------------
# https://app.lemonsqueezy.com -> Settings -> Webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=

# -- Resend Email -------------------------------------------------
# https://resend.com -> API Keys
RESEND_API_KEY=re_...

# -- Anthropic Claude ---------------------------------------------
# https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# -- Trigger.dev --------------------------------------------------
# https://trigger.dev -> Project -> API Keys
TRIGGER_API_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# -- App ----------------------------------------------------------
PUBLIC_APP_URL=http://localhost:5173
