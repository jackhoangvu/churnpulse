		"@types/node": "^25.5.2",
		"eslint": "^10.2.0",
		"prettier": "^3.8.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
